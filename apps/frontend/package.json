{
  "name": "frontend",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "docker:build": "docker buildx build -t ghcr.io/zsoltsimon97/alkfet:frontend-latest .",
    "docker:push": "docker push ghcr.io/zsoltsimon97/alkfet:frontend-latest",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "mcp": "ruler apply",
    "mcp:revert": "ruler revert"
  },
  "dependencies": {
    "@fontsource/roboto": "^5.2.10",
    "@mdi/font": "7.4.47",
    "axios": "^1.13.6",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3",
    "vuetify": "^4.0.2"
  },
  "devDependencies": {
    "@intellectronica/ruler": "^0.3.37",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^9.39.4",
    "eslint-config-vuetify": "^4.3.4",
    "npm-run-all2": "^8.0.4",
    "sass-embedded": "^1.98.0",
    "typescript": "~5.9.3",
    "unplugin-fonts": "^1.4.0",
    "vite": "^8.0.0",
    "vite-plugin-vuetify": "^2.1.3",
    "vue-tsc": "^3.2.5"
  },
  "overrides": {
    "unplugin-fonts": {
      "vite": "^8.0.0"
    }
  }
}
